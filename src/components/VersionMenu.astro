---
import VersionLink from "./VersionLink.astro";
import { useTranslations } from "../i18n/utils";
import type { Lang } from "../i18n/config";

const lang = Astro.currentLocale as Lang;
const t = useTranslations(lang);
---

<VersionLink version={'vDefault'}>{t('version.vDefault')}</VersionLink>
<VersionLink version={'v2026'}>{t('version.v2026')}</VersionLink>
<VersionLink version={'v2025'}>{t('version.v2025')}</VersionLink>