---
import type { Lang } from "../i18n/config";
import { CURRENT_VERSION } from "../version.config";
import { getTranslatedUrl } from "../i18n/utils";

const lang = Astro.currentLocale as Lang;

const { version, class: className, ...props } = Astro.props;
const pathname = decodeURIComponent(Astro.url.pathname.replace(import.meta.env.BASE_URL, ''));
const href = getTranslatedUrl(lang, version === CURRENT_VERSION ? '' : version);
const isActive = href === '/' + pathname;
---
<a href={href} class={isActive ? 'opacity-50 pointer-events-none cursor-not-allowed' : ''}>
	<slot />	
</a>

