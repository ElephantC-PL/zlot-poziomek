---
import type { Lang } from "../../i18n/config";
import { useTranslations } from "../../i18n/utils";
import BasicSection from "../../layouts/BasicSection.astro";
import { Image } from 'astro:assets';

const { data, withoutId, isLast, isEven } = Astro.props;
const lang = Astro.currentLocale as Lang;
const t = useTranslations(lang);
---

<BasicSection sectionType={data.type} withoutId={withoutId} isLast={isLast}>
  <div class={"flex flex-col md:gap-10 items-center " + (isEven ? "md:flex-row-reverse" : "md:flex-row")}>
    <div class={data.image ? "md:w-2/3" : "w-full"}>
      <h2 class="text-center text-primary">{t('section.' + data.type)}</h2>
      <slot />
    </div>
    {data.image && <div class="md:w-1/3 flex justify-center rounded-xl overflow-hidden bg-gray-100">
      <Image class="w-full max-h-80 object-contain md:max-h-none" src={data.image.src} alt={data.image.alt || "Section ilustration"} />
    </div>}
  </div>  
</BasicSection>