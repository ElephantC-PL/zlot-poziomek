
---
import Layout from '../../layouts/Static.astro';
import AboutHeroImage from '../../assets/blog-placeholder-about.jpg';
import { getAllTranslatedPaths } from '../../i18n/utils';
import { VERSIONS, CURRENT_VERSION } from '../../version.config';
import { DEFAULT_LOCALE } from '../../i18n/config';
import DefaultSection from '../../components/sections/DefaultSection.astro';
import { render } from 'astro:content';
import { getSections, getMenu } from '../../utilities/sections';
import type { Lang } from '../../i18n/config';
import WithMapSection from '../../components/sections/DirectionsSection.astro';
import TracksSection from '../../components/sections/TracksSection.astro';
import ContactSection from '../../components/sections/ContactSection.astro';
import TopSection from '../../components/sections/TopSection.astro';



export function getStaticPaths() {   	
	const paths = VERSIONS.flatMap(version => {
		const translatedRoots = getAllTranslatedPaths(version);
		return translatedRoots.map(({ params }) => {
			const { lang } = params;
			const { [version]: value, ...rest } = params;
			return ({ 
				params: { version: version === CURRENT_VERSION ? '' : value , ...rest},
				props: {version: version, translatedVersion: value, lang: lang || DEFAULT_LOCALE } 
			})
		});
	});  	
	return paths;
};

const {version, translatedVersion, lang} = Astro.props;
const sections = await getSections(lang as Lang, version);

---

<Layout
	title={translatedVersion}
	description="Lorem ipsum dolor sit amet"
	heroImage={AboutHeroImage}	
	>	
	{sections.map(async (section, index) => {
		const { Content } = await render(section);	
		switch(section.data.type) {
			case 'about':
				return (
					<TopSection 
						data={section.data} 
						isLast={index === sections.length - 1}
						isEven={index % 2 === 0}>  
						<Content />            
					</TopSection> 
				);
			case 'directions':
				return (
					<WithMapSection 
						data={section.data} 
						isLast={index === sections.length - 1}
						isEven={index % 2 === 0}>  
						<Content />            
					</WithMapSection> 
				);
			case 'tracks':				
				return (
					<TracksSection 
						data={section.data} 
						isLast={index === sections.length - 1}
						isEven={index % 2 === 0}>  
						<Content />            
					</TracksSection> 
				);
			case 'contact':						
				return (
					<ContactSection 
						data={section.data} 
						isLast={index === sections.length - 1}
						isEven={index % 2 === 0}>  
						<Content />            
					</ContactSection> 
				);
			default:
				return (
					<DefaultSection 
						data={section.data} 
						isLast={index === sections.length - 1}
						isEven={index % 2 === 0}>  
						<Content />            
					</DefaultSection> 
				);
		}
    })}
</Layout>

